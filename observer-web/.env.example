# Prisma — see prisma.config.ts notes; SQLite by default.
DATABASE_URL="file:./dev.db"

# Shared password for the auditor area (/app and /audit/*).
# Auditees uploading evidence via /audit/[id]/capture do NOT need this.
OBSERVER_PASSWORD="changeme"

# OpenRouter key used by the Python pipeline (clause/) for QMS extraction.
# Read from ~/.env or process env, NOT from observer-web/.env — set it in your shell.
# OPENROUTER_API_KEY="sk-..."
